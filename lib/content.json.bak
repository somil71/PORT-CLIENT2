  "about": {
    "seo": {
      "title": "About Sanya | Animation & VFX Artist",
      "description": "Learn about Sanya's journey as an artist at AAFT, her passion for fantasy-driven visuals, and her expertise in blending technical VFX with creative design."
    },
    "sections": {
      "intro": {
        "short_bio": "I'm an Animation and VFX artist driven by the challenge of transforming abstract concepts into immersive visual experiences. With a versatile skillset spanning cinematic compositing, video editing, and brand identity design, I blend technical precision with creative storytelling to build atmospheres that resonate emotionally."
      },
      "full_bio": {
        "paragraph_1": "My path as a visual artist began with a fascination for how simple sketches could evolve into imaginative worlds. As a student at AAFT specializing in Animation and VFX, I've dedicated myself to mastering the tools that make these transformations possible.",
        "paragraph_2": "From crafting the rhythmic flow of a video edit to creating intricate logo designs, I view every project as an opportunity to build a cohesive visual narrative. My technical toolkit includes Adobe Photoshop, Illustrator, Animate, After Effects, and Premiere Pro - tools I use to blend traditional design principles with modern motion techniques."
      },
      "passions": {
        "title": "What Drives Me",
        "items": [
          {
            "question": "What Kind of Work Do I Enjoy Most?",
            "answer": "I'm most inspired when working at the intersection of storytelling and motion. Creating fantasy-driven animations and cinematic VFX sequences allows me to build worlds from scratch - that's where my true passion lies."
          },
          {
            "question": "What Makes My Work Different?",
            "answer": "My approach is comprehensive. I handle everything from initial storyboarding and logo design through to the final VFX composite. This full-spectrum workflow ensures the artistic vision remains consistent at every stage. I don't just add effects; I build atmospheres and experiences."
          },
          {
            "question": "The Clients and Projects I'm Seeking:",
            "answer": "I'm looking to collaborate with creative brands, independent filmmakers, and studios that value imaginative storytelling. I'm particularly drawn to projects involving fantasy world-building, cinematic teasers, and brand identities that require motion design and VFX expertise."
          }
        ]
      },
      "education": {
        "title": "Education",
        "items": [
          {
            "degree": "BSc in Animation and VFX",
            "school": "AAFT (Asian Academy of Film and Television)",
            "duration": "2025 - 2028",
            "description": "My coursework focuses on core principles of 2D and 3D animation, visual effects, and post-production. I work on hands-on projects including digital illustration, storyboarding, and cinematic compositing using industry-standard Adobe tools. I'm particularly interested in how narrative-driven art can be elevated through modern motion graphics and visual storytelling techniques."
          }
        ]
      },
      "experience": {
        "title": "Experience",
        "items": [
          {
            "role": "Freelance Multimedia Designer",
            "company": "Self-Employed",
            "duration": "January 2026 - Present",
            "description": "I collaborate with small businesses and individuals to develop comprehensive brand identities, including custom logos and marketing collateral. I also provide end-to-end video editing services, transforming raw footage into engaging short-form content and promotional teasers.",
            "achievements": "I've successfully delivered complete branding packages (logos, business cards, social media assets) for clients in construction, fashion, food, and beverage industries, helping them establish a consistent and professional visual presence.",
            "tools": "Adobe Photoshop, Illustrator, Premiere Pro"
          }
        ]
      }
    }
  },
