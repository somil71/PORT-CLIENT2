      "id": "memory-corruption-comic",
      "title": "Memory Corruption",
      "slug": "memory-corruption-comic",
      "categories": ["2d-animation", "graphic-design", "freelance-academic"],
      "year": 2026,
      "type": "Academic",
      "media_type": "Case Study / Image",
      "summary": "An experimental digital comic blending fantasy with glitch aesthetics. This passion project explores pixel-fade effects and emotional visual narratives.",
      "detail_line": "Where pixels fade and memories lie.",
      "description": "A passion project merging fantasy storytelling with a unique \"glitch\" aesthetic. Memory Corruption explores a world where digital decay is visible - represented through pixelation and visual degradation that mirrors the characters' emotional states.\n\nI designed the entire visual identity for this digital comic, focusing on how typography and visual composition can reflect the psychological journey of the characters. The central technique - pixel-fade effects where characters' edges dissolve into digital noise - became the visual metaphor for memory loss itself.",
      "role": "Creator, Illustrator & Designer",
      "team": "Solo",
      "client": "AAFT",
      "goal": "To explore a unique visual style combining traditional comic layout with digital corruption effects.",
      "target_audience": "Sci-fi and fantasy fans and lovers of experimental digital art.",
      "outcome": "Complete introduction sequence and a series of concept art panels.",
      "tools": ["Adobe Photoshop", "Adobe Illustrator", "AI-Assisted Workflows (ChatGPT, Gemini, Kling, Grok)"],
      "color_mood": "Dark, Moody, Neon Blue & Static Grey",
      "process": {
        "challenge": "Visualizing memory loss in a way that felt intentional rather than messy required careful planning and experimentation with glitch effects that enhanced rather than obscured the narrative.",
        "concept": "By developing the pixel-fade technique and applying it consistently across panels, I created a cohesive visual language that communicated character states without breaking the narrative flow.",
        "steps": ["Concept sketching", "Character design", "Panel layout", "Glitch effect application", "Final lettering"],
        "proud_decisions": "The fading-pixel visual language became the emotional signature of the story.",
        "learned": "How AI tools can accelerate visual conceptualization and storyboarding while maintaining artistic direction and emotional authenticity."
      },
      "metadata": {
        "featured_homepage": true,
        "in_showreel": false,
        "detail_page": true
      }
